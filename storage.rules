rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read for avatars so people can see each other's profiles
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId.split('\\.')[0];
    }
    
    // Verifications folder: Private to the user and admins
    match /verifications/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default rule: block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
